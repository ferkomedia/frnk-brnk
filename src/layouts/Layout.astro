---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Detská kniha od Viliama Hriadela. Dobrodružný príbeh plný fantázie pre malých čitateľov. Doručíme kamkoľvek v Európe cez Packeta." } = Astro.props;
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="product" />
  <meta property="og:url" content="https://frnk-brnk.sk" />
  <meta property="og:locale" content="sk_SK" />

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#4a7c59" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Andika:wght@400;700&display=swap" rel="stylesheet">



  <title>{title}</title>

  <style is:global>
    :root {
      --color-forest: #4a7c59;
      --color-forest-dark: #3d6649;
      --color-forest-light: #6b9a78;
      --color-sky: #6b8fa3;
      --color-sky-dark: #4a6b7a;
      --color-sun: #f5c842;
      --color-sun-light: #fde68a;
      --color-earth: #c9a227;
      --color-red: #c73e3a;

      --color-cream: #fefcf6;
      --color-paper: #f9f6ef;
      --color-text: #2c3e2d;
      --color-text-light: #5a6b5c;
      --color-border: #d4d9d5;

      --font-main: 'Andika', Georgia, serif;

      --shadow-sm: 0 2px 8px rgba(44, 62, 45, 0.08);
      --shadow-md: 0 4px 16px rgba(44, 62, 45, 0.12);
      --shadow-lg: 0 8px 32px rgba(44, 62, 45, 0.16);

      --radius-sm: 8px;
      --radius-md: 16px;
      --radius-lg: 24px;

      --transition: 0.25s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

    body {
      font-family: var(--font-main);
      background: var(--color-cream);
      color: var(--color-text);
      line-height: 1.7;
      font-size: 17px;
    }

    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; height: auto; display: block; }
    ::selection { background: var(--color-sun); color: var(--color-text); }
  </style>
</head>
<body>
  <slot />
  <script is:inline src="https://widget.packeta.com/v6/www/js/library.js"></script>
  <script is:inline src="https://js.stripe.com/v3/"></script>
</body>
</html>
