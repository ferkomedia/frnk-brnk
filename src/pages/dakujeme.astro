---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Ďakujeme za objednávku! | Frnk brnk do sveta"
  description="Vaša objednávka bola úspešne prijatá. Knihu doručíme do 3-5 pracovných dní."
  noindex={true}
>

<div class="page-wrapper">
  <!-- Success Animation -->
  <div class="success-icon">
    <div class="checkmark-circle">
      <svg class="checkmark" viewBox="0 0 52 52">
        <circle class="checkmark-bg" cx="26" cy="26" r="25" fill="none"/>
        <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
      </svg>
    </div>
  </div>

  <!-- Main Content -->
  <section class="content">
    <h1>Ďakujeme za vašu objednávku!</h1>
    <p class="subtitle">Vaša kniha je na ceste k vám</p>

    <div class="order-summary">
      <h3>Čo sa stane ďalej?</h3>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div class="timeline-content">
            <strong>Teraz</strong>
            <p>Potvrdenie objednávky vo vašom emaile</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <div class="timeline-content">
            <strong>Do 24 hodín</strong>
            <p>Knihu pripravíme a podpíšeme</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <div class="timeline-content">
            <strong>Do 48 hodín</strong>
            <p>Odosielame cez Packeta</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          </div>
          <div class="timeline-content">
            <strong>3-5 dní</strong>
            <p>Kniha u vás doma!</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Audio Bonus -->
    <div class="bonus-section">
      <h3>Váš bonus: Audio ukážka</h3>
      <p>Vypočujte si ukážku kým čakáte na knihu!</p>
      <audio controls class="audio-player">
        <source src="/audio/riekanka-ukazka.mp3" type="audio/mpeg">
        Váš prehliadač nepodporuje audio.
      </audio>
      <a href="/audio/riekanka-ukazka.mp3" download class="download-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
        Stiahnuť MP3
      </a>
    </div>

    <!-- Social Share -->
    <div class="share-section">
      <h3>Zdieľajte radosť!</h3>
      <p>Povedzte kamarátom o knihe pre ich deti</p>
      <div class="share-buttons">
        <a href="https://www.facebook.com/sharer/sharer.php?u=https://frnk-brnk.sk" target="_blank" rel="noopener" class="share-btn facebook">
          <span>f</span> Facebook
        </a>
        <a href="https://wa.me/?text=Práve%20som%20objednal%20skvelú%20detskú%20knihu%20Frnk%20brnk%20do%20sveta!%20https://frnk-brnk.sk" target="_blank" rel="noopener" class="share-btn whatsapp">
          WhatsApp
        </a>
        <button class="share-btn copy" id="copy-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
          Kopírovať link
        </button>
      </div>
    </div>

    <!-- Back to Shop -->
    <div class="back-section">
      <p>Chcete objednať ďalšiu knihu ako darček?</p>
      <a href="/" class="back-btn">Späť do obchodu</a>
    </div>
  </section>

  <!-- Footer Note -->
  <footer class="footer-note">
    <p>Máte otázky? Napíšte nám na <a href="mailto:info@frnk-brnk.sk">info@frnk-brnk.sk</a></p>
  </footer>
</div>

<!-- Toast -->
<div id="toast" class="toast">Link skopírovaný!</div>

</Layout>

<style>
  .page-wrapper {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
  }

  /* Success Animation */
  .success-icon {
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
  }

  .checkmark-circle {
    width: 100px;
    height: 100px;
    margin: 0 auto 1rem;
  }

  .checkmark {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    display: block;
    stroke-width: 3;
    stroke: var(--color-forest);
    stroke-miterlimit: 10;
    box-shadow: inset 0px 0px 0px var(--color-forest);
    animation: fill 0.4s ease-in-out 0.4s forwards, scale 0.3s ease-in-out 0.9s both;
  }

  .checkmark-bg {
    stroke: var(--color-forest-light);
    stroke-width: 3;
  }

  .checkmark-check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: stroke 0.5s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards;
    stroke-width: 3;
    stroke-linecap: round;
  }

  @keyframes stroke {
    100% { stroke-dashoffset: 0; }
  }

  @keyframes scale {
    0%, 100% { transform: none; }
    50% { transform: scale3d(1.1, 1.1, 1); }
  }

  @keyframes fill {
    100% { box-shadow: inset 0px 0px 0px 50px rgba(74, 124, 89, 0.1); }
  }

  /* Content */
  .content {
    text-align: center;
  }

  h1 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .subtitle {
    color: var(--color-forest);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  /* Order Summary */
  .order-summary {
    background: white;
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-md);
    text-align: left;
  }

  .order-summary h3 {
    text-align: center;
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .timeline-icon {
    width: 40px;
    height: 40px;
    background: var(--color-paper);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .timeline-icon svg {
    width: 20px;
    height: 20px;
    color: var(--color-forest);
  }

  .timeline-content strong {
    display: block;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .timeline-content p {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* Bonus Section */
  .bonus-section {
    background: linear-gradient(135deg, var(--color-sky-dark) 0%, var(--color-sky) 100%);
    color: white;
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .bonus-section h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .bonus-section p {
    font-size: 0.95rem;
    opacity: 0.9;
    margin-bottom: 1rem;
  }

  .audio-player {
    width: 100%;
    margin-bottom: 1rem;
    border-radius: 50px;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.2);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s;
  }

  .download-btn:hover {
    background: rgba(255,255,255,0.3);
  }

  .download-btn svg {
    width: 18px;
    height: 18px;
  }

  /* Share Section */
  .share-section {
    margin-bottom: 2rem;
  }

  .share-section h3 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .share-section > p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .share-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    font-family: var(--font-main);
    border: none;
    cursor: pointer;
    transition: transform 0.2s;
  }

  .share-btn:hover {
    transform: translateY(-2px);
  }

  .share-btn.facebook {
    background: #1877f2;
    color: white;
  }

  .share-btn.whatsapp {
    background: #25d366;
    color: white;
  }

  .share-btn.copy {
    background: var(--color-forest);
    color: white;
  }

  .share-btn svg {
    width: 16px;
    height: 16px;
  }

  /* Back Section */
  .back-section {
    padding: 1.5rem;
    background: var(--color-paper);
    border-radius: 16px;
  }

  .back-section p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .back-btn {
    display: inline-block;
    color: var(--color-forest);
    text-decoration: none;
    font-weight: 600;
  }

  /* Footer */
  .footer-note {
    text-align: center;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-note p {
    font-size: 0.9rem;
    color: var(--color-text-light);
  }

  .footer-note a {
    color: var(--color-forest);
  }

  /* Toast notification */
  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--color-text);
    color: white;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    opacity: 0;
    transition: all 0.3s ease;
    z-index: 1000;
  }

  .toast.show {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }
</style>

<script>
  // Track purchase conversion
  const urlParams = new URLSearchParams(window.location.search);
  const paymentId = urlParams.get('payment_id') || 'unknown';

  if (typeof gtag !== 'undefined') {
    gtag('event', 'purchase', {
      transaction_id: paymentId,
      value: 12,
      currency: 'EUR',
      items: [{
        item_id: 'frnk-brnk-kniha',
        item_name: 'Frnk brnk do sveta',
        price: 12,
        quantity: 1
      }]
    });
  }

  // Copy link functionality
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('https://frnk-brnk.sk');
      const toast = document.getElementById('toast');
      toast?.classList.add('show');
      setTimeout(() => toast?.classList.remove('show'), 2000);
    } catch (err) {
      alert('Link: https://frnk-brnk.sk');
    }
  });
</script>
