---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Ďakujeme za objednávku — Frnk brnk do sveta">
  <div class="thank-you">
    <div class="thank-you-inner">
      <div class="check-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h1>Ďakujeme za objednávku!</h1>
      <p>Vaša objednávka bola úspešne prijatá. Na váš email sme odoslali potvrdenie.</p>
      <div class="info-box">
        <h3>Čo bude nasledovať?</h3>
        <ol>
          <li>Pripravíme vašu knihu na odoslanie</li>
          <li>Odošleme ju cez Packeta do zvoleného výdajného miesta</li>
          <li>Dostanete SMS a email keď bude balík pripravený na vyzdvihnutie</li>
        </ol>
      </div>
      <a href="/" class="back-btn">Späť na hlavnú stránku</a>
    </div>
  </div>
</Layout>

<style>
  .thank-you {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--color-paper);
  }
  .thank-you-inner {
    max-width: 500px;
    text-align: center;
  }
  .check-icon {
    width: 80px;
    height: 80px;
    background: var(--color-forest);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
  }
  .check-icon svg {
    width: 40px;
    height: 40px;
    color: white;
  }
  h1 {
    font-size: 2rem;
    color: var(--color-forest);
    margin-bottom: 1rem;
  }
  p {
    color: var(--color-text-light);
    margin-bottom: 2rem;
  }
  .info-box {
    background: white;
    padding: 1.5rem;
    border-radius: 16px;
    text-align: left;
    margin-bottom: 2rem;
    border: 1px solid var(--color-border);
  }
  .info-box h3 {
    font-size: 1.1rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .info-box ol {
    margin-left: 1.25rem;
    color: var(--color-text-light);
  }
  .info-box li {
    margin-bottom: 0.5rem;
  }
  .back-btn {
    display: inline-block;
    background: var(--color-forest);
    color: white;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    transition: all 0.25s;
  }
  .back-btn:hover {
    background: var(--color-forest-dark);
  }
</style>
