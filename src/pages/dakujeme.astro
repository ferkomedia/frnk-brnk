---
// Thank you page - po úspešnej objednávke
---

<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ďakujeme za objednávku! | Frnk brnk do sveta</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Andika:wght@400;700&display=swap" rel="stylesheet" />

  <!-- GA4 + Conversion Tracking -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-MDJY0G420X');
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MDJY0G420X"></script>
</head>
<body>
  <div class="page-wrapper">
    <!-- Success Animation -->
    <div class="success-icon">
      <div class="checkmark-circle">
        <svg class="checkmark" viewBox="0 0 52 52">
          <circle class="checkmark-bg" cx="26" cy="26" r="25" fill="none"/>
          <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
        </svg>
      </div>
      <div class="confetti">
        <span>🎉</span><span>✨</span><span>🎊</span><span>⭐</span>
      </div>
    </div>

    <!-- Main Content -->
    <section class="content">
      <h1>Ďakujeme za vašu objednávku!</h1>
      <p class="subtitle">Vaša kniha je na ceste k vám</p>

      <div class="order-summary">
        <h3>📦 Čo sa stane ďalej?</h3>
        <div class="timeline">
          <div class="timeline-item">
            <div class="timeline-icon">📧</div>
            <div class="timeline-content">
              <strong>Teraz</strong>
              <p>Potvrdenie objednávky vo vašom emaile</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-icon">📝</div>
            <div class="timeline-content">
              <strong>Do 24 hodín</strong>
              <p>Knihu pripravíme a podpíšeme</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-icon">🚚</div>
            <div class="timeline-content">
              <strong>Do 48 hodín</strong>
              <p>Odosielame cez Packeta</p>
            </div>
          </div>
          <div class="timeline-item">
            <div class="timeline-icon">🎁</div>
            <div class="timeline-content">
              <strong>3-5 dní</strong>
              <p>Kniha u vás doma!</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Audio Bonus -->
      <div class="bonus-section">
        <h3>🎧 Váš bonus: Audio ukážka</h3>
        <p>Vypočujte si ukážku kým čakáte na knihu!</p>
        <audio controls class="audio-player">
          <source src="/audio/riekanka-ukazka.mp3" type="audio/mpeg">
          Váš prehliadač nepodporuje audio.
        </audio>
        <a href="/audio/riekanka-ukazka.mp3" download class="download-btn">
          <span>⬇️</span> Stiahnuť MP3
        </a>
      </div>

      <!-- Social Share -->
      <div class="share-section">
        <h3>Zdieľajte radosť! 💝</h3>
        <p>Povedzte kamarátom o knihe pre ich deti</p>
        <div class="share-buttons">
          <a href="https://www.facebook.com/sharer/sharer.php?u=https://frnk-brnk.sk" target="_blank" class="share-btn facebook">
            <span>f</span> Facebook
          </a>
          <a href="https://wa.me/?text=Práve%20som%20objednal%20skvelú%20detskú%20knihu%20Frnk%20brnk%20do%20sveta!%20https://frnk-brnk.sk" target="_blank" class="share-btn whatsapp">
            <span>💬</span> WhatsApp
          </a>
          <button class="share-btn copy" id="copy-link">
            <span>🔗</span> Kopírovať link
          </button>
        </div>
      </div>

      <!-- Back to Shop -->
      <div class="back-section">
        <p>Chcete objednať ďalšiu knihu ako darček?</p>
        <a href="/" class="back-btn">← Späť do obchodu</a>
      </div>
    </section>

    <!-- Footer Note -->
    <footer class="footer-note">
      <p>Máte otázky? Napíšte nám na <a href="mailto:info@frnk-brnk.sk">info@frnk-brnk.sk</a></p>
    </footer>
  </div>

  <style>
    :root {
      --color-forest: #2C3E2D;
      --color-sky: #87CEEB;
      --color-sky-dark: #5BA4C9;
      --color-sun: #FFD93D;
      --color-cream: #FFF8E7;
      --color-coral: #FF6B6B;
      --color-green: #4CAF50;
      --font-main: 'Andika', sans-serif;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: var(--font-main);
      background: linear-gradient(180deg, var(--color-cream) 0%, white 100%);
      min-height: 100vh;
      color: var(--color-forest);
    }

    .page-wrapper {
      max-width: 600px;
      margin: 0 auto;
      padding: 2rem 1.5rem 3rem;
    }

    /* Success Animation */
    .success-icon {
      text-align: center;
      margin-bottom: 2rem;
      position: relative;
    }

    .checkmark-circle {
      width: 100px;
      height: 100px;
      margin: 0 auto 1rem;
    }

    .checkmark {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      display: block;
      stroke-width: 3;
      stroke: var(--color-green);
      stroke-miterlimit: 10;
      box-shadow: inset 0px 0px 0px var(--color-green);
      animation: fill 0.4s ease-in-out 0.4s forwards, scale 0.3s ease-in-out 0.9s both;
    }

    .checkmark-bg {
      stroke: #e8f5e9;
      stroke-width: 3;
    }

    .checkmark-check {
      transform-origin: 50% 50%;
      stroke-dasharray: 48;
      stroke-dashoffset: 48;
      animation: stroke 0.5s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards;
      stroke-width: 3;
      stroke-linecap: round;
    }

    @keyframes stroke {
      100% { stroke-dashoffset: 0; }
    }

    @keyframes scale {
      0%, 100% { transform: none; }
      50% { transform: scale3d(1.1, 1.1, 1); }
    }

    @keyframes fill {
      100% { box-shadow: inset 0px 0px 0px 50px rgba(76, 175, 80, 0.1); }
    }

    .confetti {
      font-size: 1.5rem;
      animation: bounce 1s ease infinite;
    }

    .confetti span {
      display: inline-block;
      animation: float 2s ease-in-out infinite;
    }

    .confetti span:nth-child(1) { animation-delay: 0s; }
    .confetti span:nth-child(2) { animation-delay: 0.2s; }
    .confetti span:nth-child(3) { animation-delay: 0.4s; }
    .confetti span:nth-child(4) { animation-delay: 0.6s; }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }

    /* Content */
    .content {
      text-align: center;
    }

    h1 {
      font-size: 1.75rem;
      margin-bottom: 0.5rem;
      color: var(--color-forest);
    }

    .subtitle {
      color: var(--color-green);
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 2rem;
    }

    /* Order Summary */
    .order-summary {
      background: white;
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      text-align: left;
    }

    .order-summary h3 {
      text-align: center;
      font-size: 1.15rem;
      margin-bottom: 1.25rem;
    }

    .timeline {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .timeline-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }

    .timeline-icon {
      width: 40px;
      height: 40px;
      background: var(--color-cream);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .timeline-content strong {
      display: block;
      font-size: 0.95rem;
      color: var(--color-forest);
    }

    .timeline-content p {
      font-size: 0.85rem;
      color: #666;
    }

    /* Bonus Section */
    .bonus-section {
      background: linear-gradient(135deg, var(--color-sky-dark) 0%, #7ab8d4 100%);
      color: white;
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }

    .bonus-section h3 {
      font-size: 1.15rem;
      margin-bottom: 0.5rem;
    }

    .bonus-section p {
      font-size: 0.95rem;
      opacity: 0.9;
      margin-bottom: 1rem;
    }

    .audio-player {
      width: 100%;
      margin-bottom: 1rem;
      border-radius: 50px;
    }

    .download-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.2);
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
      transition: background 0.2s;
    }

    .download-btn:hover {
      background: rgba(255,255,255,0.3);
    }

    /* Share Section */
    .share-section {
      margin-bottom: 2rem;
    }

    .share-section h3 {
      font-size: 1.15rem;
      margin-bottom: 0.25rem;
    }

    .share-section > p {
      color: #666;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .share-buttons {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .share-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.25rem;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      font-family: var(--font-main);
      border: none;
      cursor: pointer;
      transition: transform 0.2s;
    }

    .share-btn:hover {
      transform: translateY(-2px);
    }

    .share-btn.facebook {
      background: #1877f2;
      color: white;
    }

    .share-btn.whatsapp {
      background: #25d366;
      color: white;
    }

    .share-btn.copy {
      background: var(--color-forest);
      color: white;
    }

    /* Back Section */
    .back-section {
      padding: 1.5rem;
      background: #f8f9fa;
      border-radius: 16px;
    }

    .back-section p {
      font-size: 0.9rem;
      color: #666;
      margin-bottom: 0.75rem;
    }

    .back-btn {
      display: inline-block;
      color: var(--color-sky-dark);
      text-decoration: none;
      font-weight: 600;
    }

    /* Footer */
    .footer-note {
      text-align: center;
      margin-top: 2rem;
      padding-top: 1.5rem;
      border-top: 1px solid #eee;
    }

    .footer-note p {
      font-size: 0.9rem;
      color: #888;
    }

    .footer-note a {
      color: var(--color-sky-dark);
    }

    /* Toast notification */
    .toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: var(--color-forest);
      color: white;
      padding: 1rem 2rem;
      border-radius: 50px;
      font-weight: 600;
      opacity: 0;
      transition: all 0.3s ease;
      z-index: 1000;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
  </style>

  <!-- Toast -->
  <div id="toast" class="toast">Link skopírovaný!</div>

  <script>
    // Track purchase conversion
    const urlParams = new URLSearchParams(window.location.search);
    const orderId = urlParams.get('order_id') || 'unknown';
    const value = parseFloat(urlParams.get('value')) || 12;
    const signed = urlParams.get('signed') === 'true';

    gtag('event', 'purchase', {
      transaction_id: orderId,
      value: value,
      currency: 'EUR',
      items: [{
        item_id: 'FRNK-001',
        item_name: 'Frnk brnk do sveta',
        item_variant: signed ? 'Podpisana' : 'Klasicka',
        price: value,
        quantity: 1
      }]
    });

    // Copy link functionality
    document.getElementById('copy-link').addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText('https://frnk-brnk.sk');
        const toast = document.getElementById('toast');
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2000);
      } catch (err) {
        alert('Link: https://frnk-brnk.sk');
      }
    });
  </script>
</body>
</html>
