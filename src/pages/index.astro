<script define:vars={{ discounts }}>
document.addEventListener('DOMContentLoaded',()=>{
// GA4 view_item
if(typeof gtag!=='undefined'){gtag('event','view_item',{currency:'EUR',value:11.99,items:[{item_id:'frnk-brnk-kniha',item_name:'Frnk brnk do sveta',price:11.99,quantity:1}]});}

const pages=document.querySelectorAll('.page'),dots=document.querySelectorAll('.dot');
let currentPage=0,autoPlay;
function showPage(i){pages.forEach((p,idx)=>p.classList.toggle('active',idx===i));dots.forEach((d,idx)=>d.classList.toggle('active',idx===i));currentPage=i}
function nextPage(){showPage((currentPage+1)%pages.length)}
function startAuto(){autoPlay=setInterval(nextPage,8000)}
function stopAuto(){clearInterval(autoPlay)}
startAuto();
dots.forEach((dot,i)=>{dot.addEventListener('click',()=>{stopAuto();showPage(i);startAuto()})});
document.querySelector('.book-frame')?.addEventListener('mouseenter',stopAuto);
document.querySelector('.book-frame')?.addEventListener('mouseleave',startAuto);

const UNIT_PRICE=12,qtyInput=document.getElementById('quantity');
let shippingPrice=0;
let selectedCountry='';
function getDiscount(qty){for(let i=discounts.length-1;i>=0;i--)if(qty>=discounts[i].min)return discounts[i].discount;return 0}
function updateTotal(){const booksText=document.getElementById('total-books').textContent,booksPrice=parseFloat(booksText.replace(' €','').replace(',','.'));if(selectedCountry){document.getElementById('total-final').textContent=(booksPrice+shippingPrice).toFixed(2)+' €'}else{document.getElementById('total-final').textContent='—'}}
function updateShipping(country){if(country)selectedCountry=country;const qty=parseInt(document.getElementById('quantity').value)||1;if(qty>=10){shippingPrice=0;document.getElementById('total-shipping').textContent='ZDARMA';document.getElementById('total-shipping').style.color='var(--color-forest)';document.getElementById('total-shipping').style.fontWeight='bold'}else if(selectedCountry){const prices={'sk':3.40,'cz':4.10,'de':6.90,'at':6.90,'pl':5.50,'hu':5.50,'gb':8.90,'ie':9.90,'nl':7.90,'be':7.90,'fr':8.90,'it':8.90,'es':9.90,'pt':9.90,'ch':9.90,'ro':6.90,'bg':6.90,'hr':5.90,'si':5.90,'se':9.90,'dk':8.90,'fi':9.90,'ee':6.90,'lv':6.90,'lt':6.90,'gr':9.90,'cy':12.90,'mt':12.90,'lu':7.90,'rs':7.90};shippingPrice=prices[selectedCountry.toLowerCase()]||9.90;document.getElementById('total-shipping').textContent=shippingPrice.toFixed(2)+' €';document.getElementById('total-shipping').style.color='';document.getElementById('total-shipping').style.fontWeight=''}updateTotal()}
function updatePrices(){const qty=parseInt(qtyInput.value)||1,discount=getDiscount(qty),subtotal=qty*UNIT_PRICE,discountAmount=subtotal*(discount/100),finalBooks=subtotal-discountAmount;document.getElementById('unit-price').textContent=UNIT_PRICE.toFixed(2)+' €';document.getElementById('subtotal').textContent=finalBooks.toFixed(2)+' €';document.getElementById('total-books').textContent=finalBooks.toFixed(2)+' €';const discountRow=document.getElementById('discount-row');if(discount>0){discountRow.classList.remove('hidden');document.getElementById('discount-percent').textContent='('+discount+'%)';document.getElementById('discount-amount').textContent='−'+discountAmount.toFixed(2)+' €'}else{discountRow.classList.add('hidden')}if(selectedCountry)updateShipping();else updateTotal()}
document.getElementById('qty-minus')?.addEventListener('click',()=>{const val=parseInt(qtyInput.value)||1;if(val>1){qtyInput.value=val-1;updatePrices();if(typeof gtag!=='undefined'){const q=val-1,d=getDiscount(q),p=UNIT_PRICE*(1-d/100);gtag('event','add_to_cart',{currency:'EUR',value:p*q,items:[{item_id:'frnk-brnk-kniha',item_name:'Frnk brnk do sveta',price:p,quantity:q}]});}}});
document.getElementById('qty-plus')?.addEventListener('click',()=>{const val=parseInt(qtyInput.value)||1;if(val<100){qtyInput.value=val+1;updatePrices();if(typeof gtag!=='undefined'){const q=val+1,d=getDiscount(q),p=UNIT_PRICE*(1-d/100);gtag('event','add_to_cart',{currency:'EUR',value:p*q,items:[{item_id:'frnk-brnk-kniha',item_name:'Frnk brnk do sveta',price:p,quantity:q}]});}}});
qtyInput?.addEventListener('change',()=>{let val=parseInt(qtyInput.value)||1;if(val<1)val=1;if(val>100)val=100;qtyInput.value=val;updatePrices();if(typeof gtag!=='undefined'){const d=getDiscount(val),p=UNIT_PRICE*(1-d/100);gtag('event','add_to_cart',{currency:'EUR',value:p*val,items:[{item_id:'frnk-brnk-kniha',item_name:'Frnk brnk do sveta',price:p,quantity:val}]});}});

const packetaApiKey='4d7f960a836e9a3ddb03aebdeb2978e3';
const countrySelect=document.getElementById('delivery-country');
const pickupSection=document.getElementById('pickup-section');
const addressSection=document.getElementById('address-section');
const deliveryTypeInput=document.getElementById('delivery-type');

countrySelect?.addEventListener('change',()=>{
  const selected=countrySelect.options[countrySelect.selectedIndex];
  const type=selected?.dataset?.type||'';
  deliveryTypeInput.value=type;
  
  // Skryť obe sekcie
  pickupSection.classList.add('hidden');
  addressSection.classList.add('hidden');
  
  // Reset
  document.getElementById('packeta-point-id').value='';
  document.getElementById('packeta-selected').classList.add('hidden');
  document.getElementById('select-packeta').style.display='flex';
  
  if(type==='pickup'){
    pickupSection.classList.remove('hidden');
  }else if(type==='address'){
    addressSection.classList.remove('hidden');
  }
  
  if(countrySelect.value){
    updateShipping(countrySelect.value);
  }
  validateForm();
});

function openPacketa(){
  if(typeof Packeta==='undefined'){
    setTimeout(openPacketa,500);
    return;
  }
  const country=countrySelect.value;
  if(!country)return;
  Packeta.Widget.pick(packetaApiKey,onPacketaSelected,{country:country,language:'sk',appIdentity:'frnk-brnk.sk'});
}
function onPacketaSelected(point){if(point){document.getElementById('packeta-point-id').value=point.id;document.getElementById('point-name').textContent=point.name;document.getElementById('point-address').textContent=point.street+', '+point.city+', '+point.country;document.getElementById('select-packeta').style.display='none';document.getElementById('packeta-selected').classList.remove('hidden');validateForm()}}
document.getElementById('select-packeta')?.addEventListener('click',openPacketa);
document.getElementById('change-packeta')?.addEventListener('click',()=>{document.getElementById('select-packeta').style.display='flex';document.getElementById('packeta-selected').classList.add('hidden');openPacketa()});

// Validácia adresných polí
['address-street','address-zip','address-city'].forEach(id=>{
  document.getElementById(id)?.addEventListener('input',validateForm);
});

function validateForm(){
  const name=document.getElementById('name').value;
  const email=document.getElementById('email').value;
  const phone=document.getElementById('phone').value;
  const deliveryType=deliveryTypeInput.value;
  
  let deliveryValid=false;
  if(deliveryType==='pickup'){
    deliveryValid=!!document.getElementById('packeta-point-id').value;
  }else if(deliveryType==='address'){
    const street=document.getElementById('address-street').value;
    const zip=document.getElementById('address-zip').value;
    const city=document.getElementById('address-city').value;
    deliveryValid=!!(street&&zip&&city);
  }
  
  document.getElementById('submit-btn').disabled=!(name&&email&&phone&&deliveryValid);
}
['name','email','phone'].forEach(id=>{document.getElementById(id)?.addEventListener('input',validateForm)});

// Stripe Elements
const stripeKey='pk_live_51SIajzK7AvTQZ0XNgrY5daEJeZX4ew0fxpRaVwgahpvPAamiISdRB0SpwlPYtbrvnsJritP542yNLaZximzBZwZo007qtYg79p';
let stripe,cardNumber,cardExpiry,cardCvc;

function initStripe(){
  if(typeof Stripe==='undefined'){setTimeout(initStripe,500);return}
  stripe=Stripe(stripeKey);
  const elements=stripe.elements({locale:'sk'});
  const style={
    base:{fontFamily:'Andika, Georgia, serif',fontSize:'16px',color:'#2c3e2d','::placeholder':{color:'#5a6b5c'}},
    invalid:{color:'#e53935'}
  };
  cardNumber=elements.create('cardNumber',{style,showIcon:true});
  cardExpiry=elements.create('cardExpiry',{style});
  cardCvc=elements.create('cardCvc',{style});
  cardNumber.mount('#card-number');
  cardExpiry.mount('#card-expiry');
  cardCvc.mount('#card-cvc');
  [cardNumber,cardExpiry,cardCvc].forEach(el=>{
    el.on('change',(e)=>{
      document.getElementById('card-errors').textContent=e.error?e.error.message:'';
    });
  });
}
initStripe();

document.getElementById('order-form')?.addEventListener('submit',async(e)=>{
  e.preventDefault();
  const btn=document.getElementById('submit-btn');
  btn.disabled=true;
  btn.textContent='Spracovávam platbu...';
  
  // GA4 begin_checkout
  const checkoutQty=parseInt(document.getElementById('quantity').value)||1;
  const checkoutTotal=parseFloat(document.getElementById('total-final').textContent.replace(' €','').replace(',','.'));
  if(typeof gtag!=='undefined'){gtag('event','begin_checkout',{currency:'EUR',value:checkoutTotal,items:[{item_id:'frnk-brnk-kniha',item_name:'Frnk brnk do sveta',price:11.99,quantity:checkoutQty}]});}
  
  try{
    const deliveryType=document.getElementById('delivery-type').value;
    const formData={
      name:document.getElementById('name').value,
      email:document.getElementById('email').value,
      phone:document.getElementById('phone').value,
      quantity:checkoutQty,
      delivery_type:deliveryType,
      delivery_country:document.getElementById('delivery-country').value,
      packeta_point_id:deliveryType==='pickup'?document.getElementById('packeta-point-id').value:'',
      packeta_point_name:deliveryType==='pickup'?document.getElementById('point-name').textContent:'',
      address_street:deliveryType==='address'?document.getElementById('address-street').value:'',
      address_zip:deliveryType==='address'?document.getElementById('address-zip').value:'',
      address_city:deliveryType==='address'?document.getElementById('address-city').value:'',
      shipping_price:shippingPrice,
      total:parseFloat(document.getElementById('total-final').textContent.replace(' €','').replace(',','.'))
    };
    
    // 1. Vytvorenie PaymentIntent na serveri
    const response=await fetch('/api/create-payment',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify(formData)
    });
    const data=await response.json();
    
    if(data.error){
      document.getElementById('card-errors').textContent=data.error;
      btn.disabled=false;
      btn.textContent='Dokončiť objednávku';
      return;
    }
    
    // 2. Potvrdenie platby cez Stripe Elements
    const{error,paymentIntent}=await stripe.confirmCardPayment(data.clientSecret,{
      payment_method:{
        card:cardNumber,
        billing_details:{name:formData.name,email:formData.email,phone:formData.phone}
      }
    });
    
    if(error){
      document.getElementById('card-errors').textContent=error.message;
      btn.disabled=false;
      btn.textContent='Dokončiť objednávku';
    }else if(paymentIntent.status==='succeeded'){
      window.location.href='/dakujeme?payment_id='+paymentIntent.id;
    }
  }catch(err){
    document.getElementById('card-errors').textContent='Chyba pri spracovaní. Skúste znova.';
    btn.disabled=false;
    btn.textContent='Dokončiť objednávku';
  }
});

document.querySelectorAll('[data-modal]').forEach(btn=>{btn.addEventListener('click',()=>{const id=btn.getAttribute('data-modal');document.getElementById('modal-'+id)?.classList.add('active');document.body.style.overflow='hidden'})});
document.querySelectorAll('.modal-close, .modal-backdrop').forEach(el=>{el.addEventListener('click',()=>{document.querySelectorAll('.modal').forEach(m=>m.classList.remove('active'));document.body.style.overflow=''})});
document.addEventListener('keydown',(e)=>{if(e.key==='Escape'){document.querySelectorAll('.modal').forEach(m=>m.classList.remove('active'));document.body.style.overflow=''}});

// Cookie banner
if(!localStorage.getItem('cookies-accepted')){document.getElementById('cookie-banner')?.classList.add('active')}
document.getElementById('cookie-accept')?.addEventListener('click',()=>{localStorage.setItem('cookies-accepted','true');document.getElementById('cookie-banner')?.classList.remove('active')});
document.getElementById('cookie-settings')?.addEventListener('click',()=>{document.getElementById('modal-privacy')?.classList.add('active');document.body.style.overflow='hidden'});

// PWA Service Worker registration
let newWorker;
if('serviceWorker' in navigator){
  navigator.serviceWorker.register('/sw.js').then(reg=>{
    reg.addEventListener('updatefound',()=>{
      newWorker=reg.installing;
      newWorker.addEventListener('statechange',()=>{
        if(newWorker.state==='installed'&&navigator.serviceWorker.controller){
          document.getElementById('update-toast')?.classList.add('active');
        }
      });
    });
  });
  
  let refreshing=false;
  navigator.serviceWorker.addEventListener('controllerchange',()=>{
    if(!refreshing){refreshing=true;window.location.reload()}
  });
}

document.getElementById('update-btn')?.addEventListener('click',()=>{
  if(newWorker)newWorker.postMessage('skipWaiting');
});

// PWA Install prompt
let deferredPrompt;
const navInstall=document.getElementById('nav-install');
const installBanner=document.getElementById('install-banner');

window.addEventListener('beforeinstallprompt',(e)=>{
  e.preventDefault();
  deferredPrompt=e;
  // Zobraz button v navigácii
  if(navInstall)navInstall.style.display='flex';
  // Zobraz banner po 5 sekundách ak nebol zatvorený
  if(!localStorage.getItem('install-dismissed')){
    setTimeout(()=>{installBanner?.classList.add('active')},5000);
  }
});

// Klik na nav install button
navInstall?.addEventListener('click',async()=>{
  if(deferredPrompt){
    deferredPrompt.prompt();
    const{outcome}=await deferredPrompt.userChoice;
    if(outcome==='accepted'){
      navInstall.style.display='none';
      installBanner?.classList.remove('active');
    }
    deferredPrompt=null;
  }else{
    // Pre iOS alebo ak prompt nie je dostupný
    alert('Pre inštaláciu:\n\n• iPhone/iPad: Kliknite na "Zdieľať" → "Pridať na plochu"\n• Android: Menu prehliadača → "Inštalovať aplikáciu"');
  }
});

document.getElementById('install-btn')?.addEventListener('click',async()=>{
  if(deferredPrompt){
    deferredPrompt.prompt();
    const{outcome}=await deferredPrompt.userChoice;
    deferredPrompt=null;
    installBanner?.classList.remove('active');
    if(outcome==='accepted'&&navInstall)navInstall.style.display='none';
  }
});

document.getElementById('install-close')?.addEventListener('click',()=>{
  localStorage.setItem('install-dismissed','true');
  document.getElementById('install-banner')?.classList.remove('active');
});
});
</script>
